{
  "buildCommand": null,
  "outputDirectory": ".",
  "framework": null,
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" }
      ]
    },
    {
      "source": "/css/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/js/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/images/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "redirects": [
    { "source": "/home", "destination": "/", "statusCode": 301 },
    { "source": "/index.html", "destination": "/", "statusCode": 301 },
    { "source": "/services/marketing-automation", "destination": "/services/paid-media", "statusCode": 301 },
    { "source": "/services/cro-funnel-optimization", "destination": "/services/paid-media", "statusCode": 301 },
    { "source": "/industries/igaming", "destination": "/industries#igaming", "statusCode": 301 },
    { "source": "/industries/sports-betting", "destination": "/industries#sports-betting", "statusCode": 301 },
    { "source": "/industries/forex-trading", "destination": "/industries#forex-trading", "statusCode": 301 },
    { "source": "/industries/crypto-web3", "destination": "/industries#crypto-web3", "statusCode": 301 },
    { "source": "/industries/fintech", "destination": "/industries#fintech", "statusCode": 301 },
    { "source": "/industries/saas", "destination": "/industries#saas", "statusCode": 301 }
  ]
}
